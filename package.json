{
    "name": "softhub-monorepo",
    "version": "1.0.0",
    "description": "Fábrica de Software - Sistema Integrado",
    "scripts": {
        "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
        "dev:live": "npm run dev:live --prefix front-end",
        "dev:frontend": "npm run dev --prefix front-end",
        "dev:backend": "npm run dev --prefix back-end",
        "db:init": "npm run db:init --prefix back-end",
        "db:seed": "npm run db:seed --prefix back-end",
        "install:all": "npm install && npm install --prefix front-end && npm install --prefix back-end",
        "build": "npm run build --prefix front-end"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}